{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "code_checker": {
      "description": "Scans project code, finds 3+ weakest spots, explains why, and proposes simpler/optimal solutions",
      "mode": "subagent"
    }
  },
  "instructions": [
    "specs/state.md"
  ],
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "git commit *": "ask",
      "git push *": "ask",
      "grep *": "allow",
      "ls *": "allow",
      "mkdir *": "allow",
      "python *": "allow",
      "pip *": "allow"
    }
  }
}
