{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "code_checker": {
      "description": "Scans project code, finds 3+ weakest spots, explains why, and proposes simpler/optimal solutions",
      "mode": "subagent"
    }
  },
  "instructions": [
    "specs/state.example.md"
  ],
  "permission": {
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git diff": "allow",
      "git log": "allow",
      "git commit": "ask",
      "git push": "ask",
      "grep": "allow",
      "ls": "allow",
      "python sdd.py": "allow",
      "python -m pytest": "allow",
      "python -m ruff": "allow",
      "python -m mypy": "allow",
      "pip list": "allow",
      "pip show": "allow"
    }
  }
}
